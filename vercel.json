{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "landing.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/webhook",
      "dest": "api/index.py"
    },
    {
      "src": "/api/test-bot",
      "dest": "api/index.py"
    },
    {
      "src": "/api/debug",
      "dest": "api/index.py"
    },
    {
      "src": "/api/hello",
      "dest": "api/index.py"
    },
    {
      "src": "/app",
      "dest": "api/index.py"
    },
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/landing.html"
    }
  ]
}
